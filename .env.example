# MongoDB Configuration
MONGODB_ROOT_USERNAME=admin
MONGODB_ROOT_PASSWORD=admin123
MONGODB_USERNAME=docuser
MONGODB_PASSWORD=docuser123

# Storage Configuration
STORAGE_PROVIDER=local
# STORAGE_PROVIDER=s3

# AWS S3 Configuration (only needed if STORAGE_PROVIDER=s3)
# S3_BUCKET_NAME=invoice-documents-dev
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY=your-access-key
# AWS_SECRET_KEY=your-secret-key

# Service Discovery
EUREKA_ENABLED=false
# EUREKA_SERVER=http://eureka:8761/eureka/

# Logging
LOG_LEVEL=INFO

# MongoDB Express (debug mode)
MONGO_EXPRESS_USERNAME=admin
MONGO_EXPRESS_PASSWORD=pass